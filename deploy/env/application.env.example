# Runtime config for KrishiFarms CRM on EC2.
# Copy to /opt/krishifarms/config/application.env on EC2.
# File mode: 640, owner root:krishifarms
#
# Deploy script merges this into /opt/krishifarms/repo/.env before docker compose up.

APP_NAME=KrishiFarms CRM
APP_ENV=production
DEBUG=false
SECRET_KEY=replace-with-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Local PostgreSQL in Docker Compose (default). For RDS, set DATABASE_URL directly.
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+psycopg2://krishi:replace-with-strong-password@postgres:5432/krishifarms

CACHE_PROVIDER=memory
CACHE_TTL_SECONDS=300
REDIS_URL=

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=krishifarms-documents
S3_PRESIGNED_URL_EXPIRE_SECONDS=900

# Vercel frontend + local dev
CORS_ORIGINS=https://krishifarms.vercel.app,http://localhost:3000

DEFAULT_ORG_NAME=Krishi Farms
DEFAULT_OWNER_EMAIL=owner@krishifarms.local
DEFAULT_OWNER_PASSWORD=ChangeMe123!
DEFAULT_OWNER_NAME=Owner
