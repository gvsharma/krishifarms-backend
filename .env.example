APP_NAME=KrishiFarms CRM
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+psycopg2://krishi:krishi@postgres:5432/krishifarms

# Cache: none | memory | redis
CACHE_PROVIDER=memory
CACHE_TTL_SECONDS=300
# Required only when CACHE_PROVIDER=redis
REDIS_URL=

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=krishifarms-documents
S3_PRESIGNED_URL_EXPIRE_SECONDS=900

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DEFAULT_ORG_NAME=Krishi Farms
DEFAULT_OWNER_EMAIL=owner@krishifarms.local
DEFAULT_OWNER_PASSWORD=ChangeMe123!
DEFAULT_OWNER_NAME=Owner
